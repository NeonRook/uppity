{
	"name": "uppity",
	"version": "0.1.0",
	"homepage": "https://github.com/NeonRook/uppity#readme",
	"bugs": {
		"url": "https://github.com/NeonRook/uppity/issues"
	},
	"license": "AGPL-3.0-only",
	"author": "NeonRook <hello@neonrook.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/NeonRook/uppity.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:worker": "bun build ./src/worker/index.ts --target=bun --outfile=build/worker.js",
		"build:all": "bun run build && bun run build:worker",
		"preview": "vite preview",
		"worker": "bun run src/worker/index.ts",
		"worker:prod": "bun run build/worker.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "oxfmt && prettier --write --list-different **/*.svelte",
		"fmt:ts": "oxfmt",
		"fmt:svelte": "prettier --write --list-different **/*.svelte",
		"lint": "oxlint --type-aware --fix --fix-suggestions && eslint --fix .",
		"lint:ci": "prettier --check **/*.svelte && oxfmt --check && oxlint --type-aware && eslint .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"test:e2e": "playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:generate": "bun x @better-auth/cli@latest generate --output src/lib/server/db/auth-schema.ts --yes",
		"i18n:generate": "bun x @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"@polar-sh/better-auth": "^1.8.3",
		"@polar-sh/sdk": "^0.46.6",
		"better-auth": "^1.5.5",
		"clsx": "^2.1.1",
		"cron-parser": "^5.5.0",
		"drizzle-orm": "^0.45.1",
		"mode-watcher": "^1.1.0",
		"nanoid": "^5.1.7",
		"nodemailer": "^8.0.3",
		"pino": "^10.3.1",
		"postgres": "^3.4.8",
		"runed": "^0.37.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.15.1",
		"@internationalized/date": "^3.12.0",
		"@libsql/client": "^0.17.2",
		"@playwright/test": "^1.58.2",
		"@prettier/plugin-oxc": "^0.1.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/nodemailer": "^7.0.11",
		"@vitest/browser-playwright": "^4.1.0",
		"bits-ui": "^2.16.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-oxlint": "^1.56.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0"
	},
	"engines": {
		"bun": ">=1.0.0"
	}
}
