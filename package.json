{
	"name": "uppity",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "oxfmt && prettier --write --list-different **/*.svelte",
		"fmt:ts": "oxfmt",
		"fmt:svelte": "prettier --write --list-different **/*.svelte",
		"lint": "oxlint --type-aware --fix --fix-suggestions && eslint --fix .",
		"lint:ci": "prettier --check **/*.svelte && oxfmt --check && oxlint --type-aware && eslint .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"test:e2e": "playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:generate": "bun x @better-auth/cli@latest generate --output src/lib/server/db/auth-schema.ts --yes",
		"i18n:generate": "bun x @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"dependencies": {
		"@lucide/svelte": "^0.562.0",
		"better-auth": "^1.4.15",
		"clsx": "^2.1.1",
		"nanoid": "^5.1.6",
		"node-cron": "^4.2.1",
		"nodemailer": "^7.0.12",
		"postgres": "^3.4.8",
		"runed": "^0.37.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.1",
		"@inlang/paraglide-js": "^2.6.0",
		"@internationalized/date": "^3.10.0",
		"@libsql/client": "^0.17.0",
		"@playwright/test": "^1.57.0",
		"@prettier/plugin-oxc": "^0.1.3",
		"@sveltejs/kit": "^2.50.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/bun": "^1.3.6",
		"@types/node": "^25.0.9",
		"@types/node-cron": "^3.0.11",
		"@types/nodemailer": "^7.0.5",
		"@vitest/browser-playwright": "^4.0.15",
		"bits-ui": "^2.14.4",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-oxlint": "^1.40.0",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^17.0.0",
		"mode-watcher": "^1.1.0",
		"oxfmt": "^0.25.0",
		"oxlint": "^1.40.0",
		"oxlint-tsgolint": "^0.11.1",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.47.0",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.28.1",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.2.6",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	}
}
