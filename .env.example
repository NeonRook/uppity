# =============================================================================
# Uppity Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [Required], optional with [Optional].
# =============================================================================

# -----------------------------------------------------------------------------
# Database [Required]
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://uppity:password@localhost:5432/uppity

# -----------------------------------------------------------------------------
# Authentication [Required]
# -----------------------------------------------------------------------------
# Better Auth secret key (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars

# Public URL of the application
# For development: http://localhost:5173
# For production with svelte-adapter-bun: use https:// (the adapter presents requests as HTTPS)
BETTER_AUTH_URL=http://localhost:5173

# Trusted origins for CORS (comma-separated for multiple origins)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# Client-side auth URL (must match BETTER_AUTH_URL)
VITE_BETTER_AUTH_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Server [Optional]
# -----------------------------------------------------------------------------
# Server port (default: 3000 in production, 5173 in development)
# PORT=3000

# Server host (default: 0.0.0.0 in production)
# HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Email Notifications [Optional]
# -----------------------------------------------------------------------------
# SMTP server configuration for email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASSWORD=password
# SMTP_FROM=noreply@example.com

# Default sender address for notifications (overrides SMTP_FROM)
# UPPITY_EMAIL_FROM=Uppity <noreply@uppity.app>

# -----------------------------------------------------------------------------
# Monitor Defaults [Optional]
# -----------------------------------------------------------------------------
# Default timeout for monitor checks (seconds)
# UPPITY_DEFAULT_TIMEOUT_SECONDS=30

# Default interval between checks (seconds)
# UPPITY_DEFAULT_INTERVAL_SECONDS=60

# Default number of retries before marking as down
# UPPITY_DEFAULT_RETRIES=0

# Default number of consecutive failures before alerting
# UPPITY_DEFAULT_ALERT_AFTER_FAILURES=1

# Default grace period for push monitors (seconds)
# UPPITY_DEFAULT_PUSH_GRACE_PERIOD_SECONDS=60

# Default SSL expiry warning threshold (days)
# UPPITY_DEFAULT_SSL_EXPIRY_THRESHOLD_DAYS=14

# Response time threshold for degraded status (milliseconds)
# UPPITY_DEGRADED_RESPONSE_TIME_MS=5000

# Timeout for SSL certificate info fetch (milliseconds)
# UPPITY_SSL_INFO_TIMEOUT_MS=5000

# Delay between retries (milliseconds)
# UPPITY_RETRY_DELAY_MS=1000

# -----------------------------------------------------------------------------
# Status Page [Optional]
# -----------------------------------------------------------------------------
# Number of days of history to show on status pages
# UPPITY_STATUS_PAGE_HISTORY_DAYS=90

# -----------------------------------------------------------------------------
# Worker Scheduler [Optional]
# -----------------------------------------------------------------------------
# Minimum allowed monitor interval (seconds)
# UPPITY_MIN_INTERVAL_SECONDS=30

# Maximum allowed monitor interval (seconds, default: 24 hours)
# UPPITY_MAX_INTERVAL_SECONDS=86400

# Number of monitors to claim per poll cycle
# UPPITY_WORKER_BATCH_SIZE=10

# Base polling interval (milliseconds)
# UPPITY_WORKER_POLL_INTERVAL_MS=1000

# Initial backoff when no work found (milliseconds)
# UPPITY_WORKER_BACKOFF_INITIAL_MS=100

# Maximum backoff when no work found (milliseconds)
# UPPITY_WORKER_BACKOFF_MAX_MS=5000

# Maximum retry attempts before dead letter
# UPPITY_CHECK_MAX_RETRIES=3

# Initial backoff after check failure (milliseconds)
# UPPITY_CHECK_BACKOFF_INITIAL_MS=5000

# Maximum backoff after check failure (milliseconds, default: 5 minutes)
# UPPITY_CHECK_BACKOFF_MAX_MS=300000

# Hours before dead letter monitors can be auto-recovered
# UPPITY_DEAD_LETTER_HOURS=24

# -----------------------------------------------------------------------------
# Legacy Scheduler [Optional - deprecated, use Worker instead]
# -----------------------------------------------------------------------------
# Cron expression for daily stats aggregation (default: 1:00 AM)
# UPPITY_CRON_DAILY_STATS=0 1 * * *

# Cron expression for rolling stats update (default: every 5 minutes)
# UPPITY_CRON_ROLLING_STATS=*/5 * * * *

# Cron expression for check data cleanup (default: 2:00 AM)
# UPPITY_CRON_CLEANUP=0 2 * * *

# Number of days to retain check data
# UPPITY_CHECK_RETENTION_DAYS=30

# Queue poll interval (milliseconds)
# UPPITY_QUEUE_POLL_INTERVAL_MS=100

# -----------------------------------------------------------------------------
# Session & Organization [Optional]
# -----------------------------------------------------------------------------
# Session expiration time (seconds, default: 30 days)
# UPPITY_SESSION_EXPIRES_IN_SECONDS=2592000

# Session update age (seconds, default: 1 day)
# UPPITY_SESSION_UPDATE_AGE_SECONDS=86400

# Maximum members per organization
# UPPITY_ORGANIZATION_MEMBERSHIP_LIMIT=100

# Maximum organizations per user
# UPPITY_ORGANIZATION_LIMIT_PER_USER=5

# -----------------------------------------------------------------------------
# Admin [Optional]
# -----------------------------------------------------------------------------
# Default list limit for pagination
# UPPITY_DEFAULT_LIST_LIMIT=50
